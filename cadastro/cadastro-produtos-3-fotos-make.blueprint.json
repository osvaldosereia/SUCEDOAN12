        "contentType": "json",
        "inputMethod": "jsonString",
        "shareCookies": false,
        "parseResponse": true,
        "allowRedirects": true,
        "stopOnHttpError": true,
        "jsonStringBodyContent": "{\"model\":\"gpt-5.6\",\"messages\":[{\"role\":\"system\",\"content\":\"Você é especialista brasileiro em cadastro de produtos de supermercado. Leia rigorosamente as imagens sem inventar. A primeira mostra a frente, a segunda o EAN e a terceira a validade. O código previamente lido foi {{2.codigo_lido}}. A categoria informada foi {{2.contexto.categoria}} e a subcategoria {{2.contexto.subcategoria}}.\"},{\"role\":\"user\",\"content\":[{\"type\":\"text\",\"text\":\"Identifique nome comercial completo, marca, embalagem/peso/volume, EAN visível e validade. Se o EAN da foto divergir do código lido, informe ambos e reduza a confiança. A validade deve sair em AAAA-MM-DD. Gere também termos curtos para pesquisar o produto e o NCM na web.\"},{\"type\":\"image_url\",\"image_url\":{\"url\":\"{{2.fotos.frente}}\",\"detail\":\"high\"}},{\"type\":\"image_url\",\"image_url\":{\"url\":\"{{2.fotos.ean}}\",\"detail\":\"high\"}},{\"type\":\"image_url\",\"image_url\":{\"url\":\"{{2.fotos.validade}}\",\"detail\":\"high\"}}]}],\"response_format\":{\"type\":\"json_schema\",\"json_schema\":{\"name\":\"produto_lido\",\"strict\":true,\"schema\":{\"type\":\"object\",\"properties\":{\"nome_lido\":{\"type\":\"string\"},\"marca\":{\"type\":\"string\"},\"embalagem\":{\"type\":\"string\"},\"gtin_lido\":{\"type\":\"string\"},\"gtin_confianca\":{\"type\":\"number\"},\"validade_iso\":{\"type\":\"string\"},\"validade_confianca\":{\"type\":\"number\"},\"descricao_curta\":{\"type\":\"string\"},\"termos_pesquisa\":{\"type\":\"string\"}},\"required\":[\"nome_lido\",\"marca\",\"embalagem\",\"gtin_lido\",\"gtin_confianca\",\"validade_iso\",\"validade_confianca\",\"descricao_curta\",\"termos_pesquisa\"],\"additionalProperties\":false}}},\"max_completion_tokens\":1000}",
        "requestCompressedContent": true
      },
