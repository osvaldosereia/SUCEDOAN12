            "value": "{{7.validade_iso}}"
          },
          {
            "name": "validadeConfianca",
            "value": "{{7.validade_confianca}}"
          },
          {
            "name": "descricaoCurta",
            "value": "{{7.descricao_curta}}"
          },
          {
            "name": "ncmMinimo",
            "value": "{{2.regras.ncm_confianca_minima}}"
          },
