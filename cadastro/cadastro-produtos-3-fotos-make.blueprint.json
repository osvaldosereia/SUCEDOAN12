            "name": "ano",
            "value": "{{formatDate(now; \"YYYY\"; \"America/Cuiaba\")}}"
          },
          {
            "name": "mes",
            "value": "{{formatDate(now; \"MM\"; \"America/Cuiaba\")}}"
          }
        ],
        "language": "javascript",
        "inputFormat": "editor",
        "dependencies": [],
        "codeEditorJavascript": "  function text(v){return v===null||v===undefined?\"\":String(v).trim()}\n  function digits(v){return text(v).replace(/\\D/g,\"\")}\n  function slug(v){return text(v).normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g,\"\").toLowerCase().replace(/[^a-z0-9]+/g,\"-\").replace(/(^-|-$)/g,\"\")||\"produto\"}\n  function parseResearch(raw){try{let s=text(raw).replace(/^```(?:json)?/i,\"\").replace(/```$/,\"\").trim();const a=s.indexOf(\"{\"),b=s.lastIndexOf(\"}\");if(a>=0&&b>a)s=s.slice(a,b+1);return JSON.parse(s)}catch{return {}}}\n  function bucketFor(v){let h=0,s=text(v)||\"produto\";for(let i=0;i<s.length;i++)h=(h*31+s.charCodeAt(i))%100000;return \"b\"+String(Math.abs(h)%100).padStart(2,\"0\")}\n  const research=parseResearch(input.researchText);\n  const key=text(input.firebaseKey)||String(Date.now());\n  const scanned=digits(input.codigoLido),read=digits(input.gtinLido);\n  const gtin=(read.length>=8&&Number(input.gtinConfianca)>=0.75?read:scanned)||read||scanned;\n  const official=text(research.nome_oficial);\n  const nome=(official||text(input.nomeLido)||\"Produto a revisar\").slice(0,120);\n  const candidate=digits(research.ncm).slice(0,8);\n  const confidence=Math.max(0,Math.min(1,Number(research.confianca)||0));\n  const minimum=Number(input.ncmMinimo)||0.85;\n  const ncm=candidate.length===8&&confidence>=minimum?candidate:\"\";\n  const validity=/^\\d{4}-\\d{2}-\\d{2}$/.test(text(input.validadeIso))?text(input.validadeIso):\"\";\n  const seed=gtin||key,bucket=bucketFor(seed),base=text(input.githubImagesPath)||\"site/img/produtos_3\";\n  const file=slug(seed)+\"-\"+slug(nome).slice(0,64)+\"-\"+text(input.timestamp)+\".webp\";\n  const imagePath=base.replace(/\\/+$/,\"\")+\"/\"+bucket+\"/\"+text(input.ano)+\"/\"+text(input.mes)+\"/\"+file;\n  const imageUrl=text(input.githubRawBase).replace(/\\/+$/,\"\")+\"/\"+imagePath,now=new Date().toISOString();\n  const product={firebaseKey:key,id:key,codigo:gtin||key,gtin,nome,nome_original:text(input.nomeLido),marca:text(input.marca),embalagem:text(input.embalagem),categoria:text(input.categoria),subcategoria:text(input.subcategoria),subsubcategoria:\"\",descricao:text(input.descricaoCurta),descricao_curta:text(input.descricaoCurta),estoque:Math.max(0,Math.floor(Number(input.estoque)||0)),preco:0,preco_custo:0,preco_oferta:\"\",validade,validade_oferta:\"\",ncm,ncm_sugerido:candidate,ncm_confianca:confidence,ncm_fonte:text(research.fonte_url),ncm_justificativa:text(research.justificativa),gondola:text(input.gondola),prateleira:text(input.prateleira),situacao:\"I\",url_imagem:imageUrl,imagem:imageUrl,imagem_url:imageUrl,imagem_path:imagePath,imagem_storage:\"github\",imagem_status:\"ok\",imagens:[imageUrl],gtin_confianca:Number(input.gtinConfianca)||0,validade_confianca:Number(input.validadeConfianca)||0,cadastro_ia_revisao:ncm?\"preco_custo_ativacao\":\"ncm_preco_custo_ativacao\",origem_cadastro:\"ia_3_fotos_make\",descricao_status:\"gerada\",imagem_origem:\"ia_make_cadastro\",imagem_gerada_em:now,created_at:now,updated_at:now,last_update:Date.now()};\n  const imagePrompt=\"Crie uma única foto quadrada premium para catálogo de e-commerce usando a foto enviada como referência real e obrigatória do produto \"+nome+\". Preserve com máxima fidelidade embalagem, rótulo, logotipo do fabricante, cores, formato, proporções e volume \"+text(input.embalagem)+\". Produto grande, centralizado, ocupando 85% da imagem, fundo branco ou cinza muito claro, iluminação profissional de estúdio e sombra suave. Sem pessoas, mãos, preço, texto promocional, marca d'água, logo da loja ou elementos extras. Não redesenhe o rótulo e não invente texto. O único texto permitido é o que já existe na embalagem original.\";\n  return {productJson:JSON.stringify(product),productName:nome,gtin,ncm,ncmCandidate:candidate,ncmConfidence:confidence,imagePath,imageUrl,imagePrompt,bucket};"
      },
      "metadata": {
